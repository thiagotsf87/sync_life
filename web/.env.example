# Supabase — para trocar entre prod e homolog localmente, use NEXT_PUBLIC_SUPABASE_ENV=homolog
NEXT_PUBLIC_SUPABASE_ENV=production
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Opcional: homolog para testes locais
# NEXT_PUBLIC_SUPABASE_URL_HOMOL=https://your-homolog-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY_HOMOL=your-homolog-anon-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=SyncLife

# Usuário de teste para E2E e validação com MCP (opcional; não commitar credenciais reais)
PLAYWRIGHT_TEST_EMAIL=seu-usuario@exemplo.com
PLAYWRIGHT_TEST_PASSWORD=suasenha

# IA — MVP V3 (providers gratuitos para validação)
# Migrar para @ai-sdk/anthropic quando MRR >= R$2.000
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-key   # https://aistudio.google.com/app/apikey
GROQ_API_KEY=your-groq-key                     # https://console.groq.com/keys
BRAPI_TOKEN=your-brapi-token                   # https://brapi.dev (opcional)

# Stripe — monetização (obrigatório em prod)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=

# Supabase service role — usado apenas por webhooks server-side (NÃO expor no client)
SUPABASE_SERVICE_ROLE_KEY=

# Upstash Redis — rate limiting nas APIs de IA (opcional — sem ele, sem rate limit)
# https://console.upstash.com/
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Sentry — error tracking (opcional em dev, recomendado em prod)
# https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
